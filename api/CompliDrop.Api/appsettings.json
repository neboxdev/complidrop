    "Secret": "CHANGE_ME_DEV_ONLY_MUST_BE_AT_LEAST_32_CHARACTERS_LONG!!",
    "Issuer": "complidrop-api",
    "Audience": "complidrop-frontend",
    "SessionExpiryMinutes": 15,
    "RefreshExpiryDays": 30
  },
  "Cookies": {
    "Secure": true,
    "SameSite": "Lax"
  },
  "RateLimiting": {
    "Enabled": true
  },
  "AzureStorage": {
    "ConnectionString": "",
