    "AttemptTimeoutSeconds": 180
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-2.5-flash",
    "MaxTokens": 8192,
    "Location": "us-central1",
    "Endpoint": "vertex"
  },
  "Anthropic": {
    "ApiKey": "",
    "Model": "claude-haiku-4-5-20251001",
    "MaxTokens": 8192
  },
  "DocumentAi": {
    "Enabled": true,
    "ProjectId": "",
    "Location": "us",
    "ProcessorId": ""
  },
  "Stripe": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": "",
    "MonthlyPriceId": "",
    "AnnualPriceId": "",
    "FoundingPriceId": ""
  },
  "Resend": {
    "ApiKey": "",
    "FromEmail": "notifications@complidrop.com",
    "FromName": "CompliDrop"
  },
  "CostCeilings": {
    "FreeTierMonthlyUsd": 5,
    "PaidTierMonthlyUsd": 50
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },
  "Sentry": {
    "Dsn": "",
    "Environment": "development",
    "TracesSampleRate": 0.1
