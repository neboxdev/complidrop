{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RuleEngine": {
    "Enabled": false,
    "EnabledRuleSets": []
  },
  "TemplateCorrections": {
    "Enabled": false
  },
  "ComplianceClaims": {
    "CorrectedAdditionalInsuredWording": false
  },
  "ConnectionStrings": {
    "Database": ""
  },
  "Database": {
    "AutoMigrate": true
  },
